// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  engagements   Engagement[]
  progress      Progress[]
  
  @@map("users")
}

model Content {
  id          String      @id @default(cuid())
  title       String
  description String?
  type        ContentType
  slug        String      @unique
  viewCount   Int         @default(0)
  videoUrl    String?     @default("https://w3schools.com/html/mov_bbb.mp4")
  thumbnailUrl String?
  category    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  engagements Engagement[]
  progress    Progress[]
  
  @@index([slug])
  @@map("contents")
}

model Engagement {
  id        String        @id @default(cuid())
  userId    String
  contentId String
  type      EngagementType
  createdAt DateTime      @default(now())
  
  // Relations
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   Content       @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  @@unique([userId, contentId])
  @@map("engagements")
}

model Progress {
  id           String   @id @default(cuid())
  userId       String
  contentId    String
  lastPosition Int      @default(0)
  isCompleted  Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content      Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  @@unique([userId, contentId])
  @@map("progress")
}

enum Role {
  USER
  ADMIN
}

enum ContentType {
  VIDEO
  ARTICLE
}

enum EngagementType {
  LIKE
  BOOKMARK
}
